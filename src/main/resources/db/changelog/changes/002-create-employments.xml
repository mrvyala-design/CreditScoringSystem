<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="2-create-employments" author="Evgeny">

        <createTable tableName="employments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="client_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="salary" type="INT"/>
            <column name="experience_years" type="INT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="employments"
                baseColumnNames="client_id"
                referencedTableName="clients"
                referencedColumnNames="id"
                constraintName="fk_employments_client"/>

    </changeSet>

</databaseChangeLog>