<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <changeSet id="3-create-credit-history" author="Evgeny">

        <createTable tableName="credit_histories">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="client_id" type="BIGINT"/>
            <column name="active_loans" type="INT"/>
            <column name="overdue_count" type="INT"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="credit_histories"
                baseColumnNames="client_id"
                referencedTableName="clients"
                referencedColumnNames="id"
                constraintName="fk_history_client"/>

    </changeSet>

</databaseChangeLog>