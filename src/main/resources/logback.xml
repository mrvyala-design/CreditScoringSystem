<configuration>

    <appender name="FILE"
              class="ch.qos.logback.core.FileAppender">

        <file>D:\Idea Projects\MavenProjects\CreditScoringSystem\logs\application.log</file>

        <append>false</append>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss}
                %-5level
                %logger{36}
                -
                %msg%n
            </pattern>
        </encoder>

    </appender>

    <logger name="controller" level="INFO"/>
    <logger name="service" level="INFO"/>

    <logger name="org.hibernate" level="WARN"/>

    <logger name="java.sql" level="WARN"/>

    <root level="ERROR">

        <appender-ref ref="FILE"/>

    </root>

</configuration>